{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Scan: all args except --quiet",
            "type": "debugpy",
            "request": "launch",
            "module": "ipi_check.cli.main",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "scan",
                //"${workspaceFolder}",
                "/Users/vkochetkov/Repositories/jqwik",
                "--llm-base-url",
                "https://api.deepseek.com",
                "--llm-model",
                "deepseek/deepseek-v4-flash",
                "--llm-api-token",
                "${DEEPSEEK_API_KEY}",
                "--output",
                "${workspaceFolder}/report.sarif",
                "--no-gitignore",
                "--exclude",
                "**/node_modules/**",
                "--exclude",
                "**/.venv/**"
            ]
        },
        {
            "name": "Scan: minimal (repo + stdout)",
            "type": "debugpy",
            "request": "launch",
            "module": "ipi_check.cli.main",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "scan",
                "${workspaceFolder}"
            ]
        },
        {
            "name": "Scan: with LLM + SARIF file",
            "type": "debugpy",
            "request": "launch",
            "module": "ipi_check.cli.main",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "scan",
                "${workspaceFolder}",
                "--llm-base-url",
                "https://api.deepseek.com",
                "--llm-model",
                "deepseek/deepseek-v4-flash",
                "--llm-api-token",
                "${DEEPSEEK_API_KEY}",
                "--output",
                "${workspaceFolder}/report.sarif"
            ]
        },
        {
            "name": "Scan: quiet mode (SARIF only, no progress)",
            "type": "debugpy",
            "request": "launch",
            "module": "ipi_check.cli.main",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "scan",
                "${workspaceFolder}",
                "--quiet"
            ]
        },
        {
            "name": "Scan: with excludes, no gitignore",
            "type": "debugpy",
            "request": "launch",
            "module": "ipi_check.cli.main",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "scan",
                "${workspaceFolder}",
                "--no-gitignore",
                "--exclude",
                "**/node_modules/**",
                "--exclude",
                "**/.venv/**",
                "--exclude",
                "**/__pycache__/**"
            ]
        },
        {
            "name": "Scan: current file's directory",
            "type": "debugpy",
            "request": "launch",
            "module": "ipi_check.cli.main",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "scan",
                "${fileDirname}"
            ]
        }
    ]
}